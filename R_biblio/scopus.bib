	author = {Schmidt, Matthias and Gonda, Robert and Transiskus, Sebastian},
	title = {Environmental degradation at Lake Urmia (Iran): exploring the causes and their impacts on rural livelihoods},
	year = {2021},
	journal = {GeoJournal},
	volume = {86},
