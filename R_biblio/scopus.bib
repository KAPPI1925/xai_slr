@ARTICLE{Scheffran201127,
	author = {Scheffran, Jürgen and Battaglini, Antonella},
	title = {Climate and conflicts: The security risks of global warming},
	year = {2011},
	journal = {Regional Environmental Change},
	volume = {11},
	number = {SUPPL. 1},
	pages = {27 – 39},
	doi = {10.1007/s10113-010-0175-8},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-79952103206&doi=10.1007%2fs10113-010-0175-8&partnerID=40&md5=e5c22e6f569bc8f96fa24f4ca50b16bc},
	affiliations = {KlimaCampus, Institute for Geography, Universität Hamburg, Hamburg, Germany; Transdisciplinary Concepts and Methods, Potsdam Institute for Climate Impact Research, Potsdam, Germany; Zentrum für Marine und Atmosphärische Wissenschaften (ZMAW), 20146 Hamburg, Bundesstr. 53, Germany},
	abstract = {Since the publication of the fourth assessment report of the Intergovernmental Panel on Climate Change in 2007, the securitization of global warming has reached a new level. Numerous public statements and a growing research literature have discussed the potential security risks and conflicts associated with climate change. This article provides an overview of this debate and introduces an assessment framework of climate stress, human security and societal impacts. Key fields of conflict will be addressed, including water stress, land use and food security, natural disasters and environmental migration. A few regional hot spots of climate security will be discussed, such as land-use conflicts in Northern Africa; floods, sea-level rise and human security in Southern Asia; glacier melting and water insecurity in Central Asia and Latin America; water conflicts in the Middle East; climate security in the Mediterranean; and the potential impact on rich countries. Finally, concepts and strategies will be considered to minimize the security risks and move from conflict to cooperation in climate policy. © 2010 Springer-Verlag.},
	author_keywords = {Climate security; Environmental conflict; Human security; Regional hot spots; Resource scarcity; Risks of global warming},
