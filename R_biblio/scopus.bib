@ARTICLE{McMichael2023,
	author = {McMichael, Celia and Schwerdtle, Patricia Nayna and Ayeb-Karlsson, Sonja},
	title = {Waiting for the wave, but missing the tide: Case studies of climate-related (im)mobility and health},
	year = {2023},
