@ARTICLE{Bernzen2019,
	author = {Bernzen, Amelie and Jenkins, J. Craig and Braun, Boris},
	title = {Climate change-induced migration in coastal Bangladesh? A critical assessment of migration drivers in rural households under economic and environmental stress},
