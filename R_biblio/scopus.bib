@ARTICLE{Morris202357,
	author = {Morris, Erin and Cousins, Joshua J. and Feldpausch-Parker, Andrea},
	title = {Transformation and recognition: Planning just climate havens in New York State},
	year = {2023},
	journal = {Environmental Science and Policy},
	volume = {146},
	pages = {57 – 65},
	doi = {10.1016/j.envsci.2023.05.004},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85158860249&doi=10.1016%2fj.envsci.2023.05.004&partnerID=40&md5=2bb28e127edda3de1b196e890736cac3},
	affiliations = {Department of Environmental Studies, SUNY College of Environmental Science and Forestry, 106 Marshall Hall, Syracuse, 13210, NY, United States},
	abstract = {Climate change is altering the context of human mobility due to disasters such as sea-level rise, forest fires, and other extreme events. It is also changing how places plan and adapt to these chaotic events. In this paper we examine how climate destinations, or host communities, are preparing for potential climate related in-migration in their climate adaptation planning. While no place will be left untouched by climate change, a number of cities and communities across Upstate New York consider themselves “climate havens” due to their lower risk to many climate impacts, such as sea level rise, access to freshwater resources, and infrastructure to accommodate growth. Within this context, what does it mean to plan a just climate haven? What types of policy and planning might be needed? How are planners and practitioners framing adaptation approaches? Using Q-methodology, we reveal two dominant perspectives among planners and activists in Upstate New York on how to plan just climate havens. The first is a transformational view that looks to address the social, political, and economic drivers of vulnerability. The second is a recognition view that looks to address legal and legislative shortcomings in how to support climate migrants. Points of consensus on how to build just climate havens between the two groups include co-production and co-design, workforce development, food security, and safe and affordable housing. We suggest that these two perspectives frame justice in two distinct—but overlapping—ways and provide a shared basis on how to consider planning a just climate haven. © 2023 Elsevier Ltd},
	author_keywords = {Adaptation; Climate justice; Climate migration; Climate mobilities; Q-methodology},
	keywords = {New York [New York (STT)]; New York [United States]; United States; fresh water; climate change; climate effect; planning practice; policy approach; Article; climate change; climate change mitigation; economic aspect; environmental impact; environmental planning; environmental policy; environmental sustainability; environmental vulnerability; food security; government; housing; human; law; legal aspect; migration; New York; politics; safety climate; sea level rise; social aspect; social justice; workforce},
