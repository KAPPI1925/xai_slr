@ARTICLE{Dosset2025607,
author={Dosset, A. and Dang, L.M. and Alharbi, F. and Habib, S. and Alam, N. and Park, H.Y. and Moon, H.},
title={Cassava disease detection using a lightweight modified soft attention network},
