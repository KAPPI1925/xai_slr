author={Aminu, R. and Cook, S.M. and Ljungberg, D. and Hensel, O. and Nasirahmadi, A.},
title={Improving the performance of machine learning algorithms for detection of individual pests and beneficial insects using feature selection techniques},
journal={Artificial Intelligence in Agriculture},
year={2025},
