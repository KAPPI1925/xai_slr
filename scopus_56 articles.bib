@ARTICLE{Srinivasan2025,
author={Srinivasan, S. and Somasundharam, L. and Rajendran, S. and Singh, V.P. and Mathivanan, S.K. and Moorthy, U.},
title={DBA-ViNet: an effective deep learning framework for fruit disease detection and classification using explainable AI},
