@ARTICLE{Verma2025,
author={Verma, P.R. and Pantola, D. and Singh, N.P.},
title={Plant Disease Detection with Transfer Learning: Evaluating the Impact of Various Loss Functions and Explainable AI},
journal={Journal of Agricultural, Biological, and Environmental Statistics},
year={2025},
doi={10.1007/s13253-025-00691-9},
art_number={125239},
note={cited By 3},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-105003306128&doi=10.1007%2fs13253-025-00691-9&partnerID=40&md5=c1cbbcd70f4c3eb20c119a5bbe88113f},
affiliation={School of Computer Science Engineering and Technology, Bennett University, Uttar Pradesh, Greater Noida, 201310, India; School of Artificial Intelligence, Bennett University, Uttar Pradesh, Greater Noida, 201310, India},
abstract={It is crucial for correctly recognizing plant diseases for improving agricultural productivity and managing food resources optimally. This work evaluates the effectiveness of various loss functions in transfer learning (TL) for plant disease detection using the PlantVillage dataset, which includes 38 plant classes and is known for its diversity. We assess the performance of several deep learning (DL) models, including VGG16, VGG19, ResNet50, DenseNet121, AlexNet, SqueezeNet, MobileNetV2, and GoogleNet. Each model is trained with five different loss functions: cross-entropy, dice loss, focal loss, IoU loss, and label smoothing cross-entropy. Additionally, we utilized the gradient-weighted class activation mapping++ (Grad-CAM++), an explainable artificial intelligence (XAI) strategy, to upgrade the clarity and confidence on the results by providing insights into model decisions for single-image predictions. Our experiments show that label smoothing cross-entropy and cross-entropy loss functions show the best performances for the trained models. This study underscores the robustness of TL for the diagnosis of plant diseases, highlighting the implications of the appropriate selection of loss function and the benefits of XAI for diagnostic effectiveness. Our findings offer valuable information for the deployment of DL solutions for an enhanced and accurate monitoring of plant disease in agricultural settings, with greater transparency in model decisions. © International Biometric Society 2025.},
author_keywords={Convolutional neural networks (CNNs);  Deep learning;  Explainable artificial intelligence (XAI);  Loss functions;  Transfer learning},
