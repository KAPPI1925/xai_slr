@article{princeCSXAILightweight2D2024b,
  title = {{{CSXAI}}: A Lightweight {{2D CNN-SVM}} Model for Detection and Classification of Various Crop Diseases with Explainable {{AI}} Visualization},
  shorttitle = {{{CSXAI}}},
  author = {Prince, Reazul Hasan and Mamun, Abdul Al and Peyal, Hasibul Islam and Miraz, Shafiun and Nahiduzzaman, {\relax Md}. and Khandakar, Amith and Ayari, Mohamed Arselene},
  year = 2024,
