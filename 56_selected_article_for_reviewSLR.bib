@article{mohammadnasarExplainableAIMango2025b,
  title = {The {{Explainable AI}} for Mango Leaf Disease Detection: Bridging the Gap between Model Accuracy and Farmers Usability},
  shorttitle = {The {{Explainable AI}} for Mango Leaf Disease Detection},
  author = {{Mohammad Nasar} and {Md. Abu Kausar} and {Md Abu Nayyer} and {Vikash Kumar} and {Md. Arshad Anwer}},
  year = 2025,
