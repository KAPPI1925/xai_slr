  pages = {41890},
  issn = {2045-2322},
  doi = {10.1038/s41598-025-25888-3},
  urldate = {2026-04-27},
  abstract = {Abstract             Early and accurate detection of diseases is very important for the health of crops and ensuring sustainable agricultural productivity. This paper proposes OptiNet-B3, a novel approach and an efficient deep model for the multiclass classification of fruit and leaf diseases for apples, bananas, and oranges. Through two diverse and comprehensive image datasets, the model performs well for both fruit 13,602 images and leaf 11,199 images classification. OptiNet-B3 optimizes learning in low computational budget by integrating Mish activation, Convolutional Block Attention Module (CBAM), Group Normalization, and knowledge distillation. Great care in preprocessing and augmenting data was taken to improve generalization. Comparison with state-of-the-art models-including DenseNet121, ResNet50, MobileNetV3, and InceptionV3-based models-reveals that OptiNet-B3 substantially outperforms in terms of accuracy, with 98.12\% and 99.23\% on the fruit and leaf datasets, respectively. Due to its light-weight architecture, real-time deployment for in-field diagnosis on mobile and edge devices is much more feasible. The results underscore the potential of explainable, AI-driven tools in transforming plant disease management practices.},
  langid = {english},
  annotation = {Read\_Status: Selected\\
Read\_Status\_Date: 2026-05-03T01:56:04.571Z},
  file = {C:\Users\kamalesh\My Drive\College\3. PhD\Zotero\storage\5FJ8IRLR\Naveen and Ajitha - 2025 - OptiNet-B3 a lightweight explainable deep learning model for multiclass classification of fruit and.pdf}
}

@article{nazriDeployableExplainableDeep2026b,
  title = {Towards Deployable and Explainable Deep Learning Models for Paddy Leaf Disease Classification in {{R}}: {{A}} Comparative Study of {{CNN}} Architectures with {{SHAP}} and {{LIME}}},
  shorttitle = {Towards Deployable and Explainable Deep Learning Models for Paddy Leaf Disease Classification in {{R}}},
  author = {Nazri, Muhammad Aiman Wafi and Razak, Tajul Rosli},
  year = 2026,
  month = mar,
  journal = {Expert Systems with Applications},
  volume = {300},
  pages = {130337},
  issn = {09574174},
  doi = {10.1016/j.eswa.2025.130337},
  urldate = {2026-04-27},
  abstract = {Accurate identification of paddy leaf diseases is vital for timely intervention and sustainable rice production. This study proposes a novel, fully R-based deep learning framework for paddy leaf disease classification that integrates model performance evaluation, statistical testing, and post hoc explainability. The methodology incorporates four CNN architectures-Baseline CNN, ResNet50, DenseNet121, InceptionV3-and a novel Hybrid CNN that performs deep feature-level fusion across all models. All networks were trained using a curated dataset comprising six paddy disease categories, with extensive data augmentation applied to enhance generalization. The dataset consisted of 6000 images, split into 4800 for training and 1200 for validation across all classes. A structured hyperparameter optimization strategy was implemented using the tfruns package, and all models were benchmarked using confusion matrix-derived metrics. The Hybrid CNN -- Simple Ensemble achieved the best overall performance, recording a mean accuracy of 0.821 and a mean Macro-F1 of 0.818, thereby surpassing the best single model (DenseNet121 Fine-tuned, accuracy 0.793). Statistical validation using McNemar's test confirmed that the Hybrid Simple Ensemble's predictions differed significantly from those of other models. At the same time, Cohen's Kappa analysis indicated only moderate agreement with DenseNet121 and weaker agreement with InceptionV3 and ResNet50. To ensure transparency, explainable AI (XAI) techniques-such as SHAP, LIME, and Grad-CAM-were employed to visualize and quantify model attention. Results demonstrated that the Hybrid Simple Ensemble consistently focused on biologically meaningful lesion and streak regions, with higher faithfulness scores than DenseNet121, thereby enhancing both predictive accuracy and interpretability. This study presents a reproducible and interpretable deep learning pipeline for agricultural diagnostics, demonstrating the viability of R for end-to-end CNN development. The inclusion of a hybrid CNN ensemble strategy, coupled with integrated SHAP, LIME, and Grad-CAM explanations, establishes a stronger foundation for deployable, trustaware plant disease detection systems.},
  langid = {english},
  annotation = {Read\_Status: Selected\\
Read\_Status\_Date: 2026-05-03T02:07:51.912Z},
  file = {C:\Users\kamalesh\My Drive\College\3. PhD\Zotero\storage\J7LH9Q9H\Nazri and Razak - 2026 - Towards deployable and explainable deep learning models for paddy leaf disease classification in R.pdf}
}

@article{nirobCOLD12MultilevelFeature2025,
  title = {{{COLD-12}}: {{A}} Multi-Level Feature Extraction Hybrid {{CNN Model}} for Accurate Cotton Disease Diagnosis},
  shorttitle = {{{COLD-12}}},
  author = {Nirob, Md. Asraful Sharker and Bishshash, Prayma and Siam, A K M Fazlul Kobir},
  year = 2025,
  month = jun,
  journal = {Franklin Open},
  volume = {11},
  pages = {100263},
  issn = {27731863},
  doi = {10.1016/j.fraope.2025.100263},
  urldate = {2026-04-27},
  abstract = {Cotton leaf diseases are common agricultural issues and multifaceted threats to millions of farmers worldwide. This study aims to provide an up-to-date approach to diagnosing diseases of cotton leaves using advanced DL (Deep Learning) that is accessible and actionable by farmers, bridging the gap between technology and agricultural practices. The key to this study was the construction of a diverse dataset comprising 5722 highresolution images collected from three independent sources and further enriched with expert guidance in annotation. Advanced preprocessing was done, like denoising, sharpening, and color balancing, to increase the quality of images, while augmentation increased generalization and reduced overfitting. In it, COLD-12 is proposed, which has achieved a promising result by incorporating Atrous Spatial Pyramid Pooling with Squeezeand-Excitation blocks for improved channel attention in its multi-level feature extraction. The training accuracy of the model was 99.94 \%, and the validation accuracy was 99.24 \%, which indicates that the model was robust with very low validation loss. The inner workings of the COLD-12 model were interpreted by using explainable AI techniques such as Grad-CAM, Grad-CAM++, and Layer-CAM. It showed advantages compared to state-of-the-art models such as VGG16, VGG19, Xception, DenseNet121, and InceptionResNetV2.The impact of batch size, K-fold cross-validation, and preprocessing techniques was also explored, resulting in improved accuracy and interpretability. An interactive web tool was developed to bridge research and real-world applications, offering farmers a convenient assistant for diagnosing cotton leaf diseases, thus supporting sustainable farming initiatives.},
  langid = {english},
  annotation = {Read\_Status: Selected\\
Read\_Status\_Date: 2026-05-02T02:01:01.135Z},
  file = {C:\Users\kamalesh\My Drive\College\3. PhD\Zotero\storage\H3NL3KD9\Nirob et al. - 2025 - COLD-12 A multi-level feature extraction hybrid CNN Model for accurate cotton disease diagnosis.pdf}
}

