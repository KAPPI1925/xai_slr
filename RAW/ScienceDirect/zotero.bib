	pages = {1--6},
	file = {PDF:C\:\\Users\\kamalesh\\My Drive\\College\\3. PhD\\Zotero\\storage\\PQC9HCLZ\\Mahmud et al. - 2023 - Explainable AI for Tomato Leaf Disease Detection Insights into Model Interpretability.pdf:application/pdf},
