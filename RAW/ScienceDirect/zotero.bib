	file = {Full Text:C\:\\Users\\kamalesh\\My Drive\\College\\3. PhD\\Zotero\\storage\\L7P7PGXA\\Mohammad Nasar et al. - 2025 - The Explainable AI for mango leaf disease detection bridging the gap between model accuracy and far.pdf:application/pdf},
